<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.hellofx.controllers.MenuController"
            prefHeight="400.0" prefWidth="600.0">

    <ListView fx:id="menuList" layoutX="10" layoutY="10" prefHeight="200.0" prefWidth="580.0"/>
    <Button fx:id="orderButton" layoutX="10" layoutY="220" text="Order" onAction="#goToOrderPage"/>
</AnchorPane>
